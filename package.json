{
  "name": "parceliq",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server/_core/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite build && concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch --experimental-specifier-resolution=node dist/server/_core/index.js",
    "dev:client": "vite",
    "build": "npm install --include=dev && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/_core/index.js",
    "sync:rod": "node jobs/syncRegisterOfDeeds.mjs",
    "sync:rod:full": "node jobs/syncRegisterOfDeeds.mjs --full-reload",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^4.2.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.18.3",
    "lucide-react": "^0.344.0",
    "mysql2": "^3.9.3",
    "nanoid": "^5.0.7",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.5",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "wouter": "^3.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.20.14",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7"
  }
}
