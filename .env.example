# Copy this to .env and fill in your values
# NEVER commit .env to git

# Postgres — Render PostgreSQL or local
DATABASE_URL=postgresql://user:password@host:5432/parceliq

# App
NODE_ENV=development
PORT=10000
# Public URL (no trailing slash) — used for Stripe success/cancel redirects and report download links
APP_URL=http://localhost:10000

# Stripe — https://dashboard.stripe.com/test/apikeys
# Server checkout + webhooks require the SECRET key (sk_test_...). Never commit or paste in chat.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# From: Developers → Webhooks → endpoint → Signing secret (whsec_...)
# Local dev: run `npm run stripe:listen` in a second terminal
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Resend — https://resend.com/api-keys (emails PDF after purchase)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Parcelogik <reports@yourdomain.com>

# Register of Deeds weekly sync (jobs/syncRegisterOfDeeds.mjs)
# ROD_CSV_URL=https://example.com/buncombe/open-data/property-sales.csv
# ROD_CSV_PATH=./Buncombe_County_Property_Sales_Data.csv
